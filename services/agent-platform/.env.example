# ============================================
# PostgreSQL 数据库配置
# ============================================
PG_CONNECTION_STRING=postgresql://postgres:postgres@localhost:5432/agentdb

# ============================================
# Agent 配置文件路径（可选，自动检测）
# ============================================
# AGENT_CONFIG=./openclaw.json
# AGENT_CONFIG=/home/user/.openclaw/openclaw.json

# ============================================
# DashScope API 配置 (仅 agents.yaml 格式使用)
# ============================================
DASHSCOPE_API_KEY=your-api-key-here
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=deepseek-v3
LLM_TEMPERATURE=0.7
REQUEST_TIMEOUT=60000

# ============================================
# Embedding 模型配置 (可选)
# ============================================
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=bge-m3
OLLAMA_BASE_URL=http://localhost:11434

# ============================================
# 服务端口
# ============================================
PORT=3000
