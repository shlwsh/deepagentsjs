{
  "name": "deepagentsjs-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Deep Agents - a library for building controllable AI agents with LangGraph",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"bun run dev:service\" \"bun run dev:frontend\"",
    "dev:service": "cd services/agent-platform && bun run dev",
    "dev:frontend": "cd src-frontend && bun run dev",
    "build": "pnpm --filter \"./libs/*\" --filter \"./libs/providers/*\" build",
    "clean": "pnpm --filter \"./libs/*\" clean",
    "typecheck": "pnpm --filter \"./libs/*\" typecheck",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "test": "pnpm format:check && pnpm lint && pnpm --filter \"./libs/*\" test",
    "test:unit": "pnpm --filter \"./libs/*\" test:unit",
    "test:int": "pnpm --filter \"./libs/*\" --filter \"./libs/providers/*\" test:int",
    "test:watch": "pnpm --filter \"./libs/*\" test:watch",
    "test:coverage": "pnpm --filter \"./libs/*\" test:coverage",
    "changeset:version": "changeset version",
    "release": "pnpm build && changeset publish",
    "mygit": "bun run scripts/git-auto-commit.ts",
    "mymerge": "bun run scripts/git-auto-merge.ts",
    "updateproject": "bun run scripts/update-project.ts",
    "createskill": "bun run scripts/create-skill.ts",
    "savesession": "bun run scripts/session-tool.ts save",
    "loadsession": "bun run scripts/session-tool.ts load",
    "killallport": "bun run scripts/killallport.ts",
    "killports": "bun run scripts/killallport.ts",
    "update": "bun run scripts/ai-upgrade-version.ts",
    "mytag": "bun run scripts/mytag.ts",
    "test:skill-flow": "bun run scripts/test-skill-creation-flow.ts",
    "verify-lsp": "bun run scripts/verify-lsp.ts",
    "backup": "bun run scripts/backup-database.ts",
    "saveknowledge": "bun run scripts/save-knowledge.ts",
    "restoreknowledge": "bun run scripts/restore-knowledge.ts"
  },
  "homepage": "https://docs.langchain.com/oss/javascript/deepagents",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/langchain-ai/deepagentsjs.git"
  },
  "keywords": [
    "ai",
    "agents",
    "langgraph",
    "langchain",
    "typescript",
    "llm"
  ],
  "author": "LangChain",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/langchain-ai/deepagentsjs/issues"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.29.8",
    "@langchain/core": "^1.1.40",
    "@langchain/openai": "^1.4.4",
    "@tsconfig/recommended": "^1.0.13",
    "concurrently": "^9.2.1",
    "dotenv": "^17.4.2",
    "eslint-plugin-no-instanceof": "^1.0.1",
    "globals": "^17.3.0",
    "jiti": "^2.6.1",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": "pnpm run lint",
    "*": "pnpm run format --no-error-on-unmatched-pattern"
  },
  "packageManager": "pnpm@10.29.2",
  "overrides": {
    "minimatch@<3.1.4": "3.1.4",
    "minimatch@>=9 <10.2.1": "10.2.4",
    "fast-xml-parser@>=4.0.0-beta.3 <=5.5.6": "5.5.10",
    "rollup@>=4.0.0 <4.59.0": "4.59.0",
    "lodash@<=4.17.23": "4.18.1",
    "picomatch@<2.3.2": "2.3.2",
    "picomatch@>=4.0.0 <4.0.4": "4.0.4",
    "flatted@<3.4.2": "3.4.2"
  },
  "workspaces": [
    "libs/*",
    "libs/providers/*",
    "internal/*",
    "evals/*",
    "examples",
    "examples/**/*",
    "services/*",
    "src-frontend"
  ]
}
